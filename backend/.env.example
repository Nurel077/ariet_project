# Backend Environment Variables for Railway Deployment

# Server Configuration
NODE_ENV=production
PORT=4000

# MongoDB Configuration (Use MongoDB Atlas for production)
MONGO_URL=mongodb+srv://username:password@cluster0.mongodb.net/food-delivery?retryWrites=true&w=majority

# Frontend URLs (Will be set by Railway variables)
FRONTEND_URL=https://your-frontend-url.railway.app
ADMIN_URL=https://your-admin-url.railway.app

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this

# Stripe Configuration (Optional)
STRIPE_API_KEY=your_stripe_api_key

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
