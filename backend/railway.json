{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node server.js",
    "restartPolicyMaxRetries": 5,
    "healthChecks": {
      "enabled": true,
      "interval": 30,
      "timeout": 10,
      "path": "/"
    }
  }
}
